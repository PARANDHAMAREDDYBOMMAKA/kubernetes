FROM golang:1.24-alpine AS builder
ENV GOTOOLCHAIN=auto
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -trimpath -o /kube-apiserver ./cmd/apiserver

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /kube-apiserver /kube-apiserver
USER nonroot:nonroot
EXPOSE 8080
ENTRYPOINT ["/kube-apiserver"]
